# ─── App ───────────────────────────────────────────────────────────────────────
# Base URL of this Next.js app (used by the scheduler to call the run API)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL of your Flask prediction site (shown as "back" link in the nav)
NEXT_PUBLIC_FLASK_URL=http://localhost:5000
# ─── Video export requirements ────────────────────────────────────────────────
# Downloadable MP4 exports require ffmpeg installed and available on PATH.
# Voiceover synthesis also requires OPENAI_API_KEY.

# ─── OpenAI (caption generation) ───────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Twitter / X ───────────────────────────────────────────────────────────────
# Create an app at https://developer.twitter.com
# Install: npm install twitter-api-v2
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ─── Instagram (Facebook Graph API) ────────────────────────────────────────────
# Requires an Instagram Business account linked to a Facebook Page
# https://developers.facebook.com/docs/instagram-api/getting-started
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ─── Facebook ──────────────────────────────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ─── OAuth app credentials (for popup connect flow) ───────────────────────────
# Instagram/Facebook (Meta)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# X / Twitter OAuth 2.0
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube (Google OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Pinterest OAuth
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
